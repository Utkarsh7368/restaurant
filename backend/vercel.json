{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/menu",
      "dest": "server.js",
      "headers": {
        "Cache-Control": "s-maxage=60, stale-while-revalidate=300"
      }
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
